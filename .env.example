# ==============================================================================
# Application Configuration
# ==============================================================================
# The name of the application displayed in the UI (e.g., login page, sidebar)
NEXT_PUBLIC_APP_NAME="Kiprex Cashflow"

# The environment the application is running in (development, staging, production)
NEXT_PUBLIC_APP_ENV="development"

# ==============================================================================
# API Configuration
# ==============================================================================
# The public URL of the backend API
# Local development: http://localhost:8000/api/v1
# Production: https://api.yourdomain.com/api/v1
NEXT_PUBLIC_API_URL="http://localhost:8000/api/v1"

# The public WebSocket URL for real-time features
# Local development: ws://localhost:8000/api/v1
# Production: wss://api.yourdomain.com/api/v1
NEXT_PUBLIC_WS_URL="ws://localhost:8000/api/v1"
